# Streamlit Cloud secrets — copy to .streamlit/secrets.toml locally
# or paste into Streamlit Cloud dashboard under App Settings > Secrets
# NOTE: secrets.toml is gitignored — never commit real keys

LLM_BASE_URL = "https://integrate.api.nvidia.com/v1"
LLM_API_KEY = "nvapi-..."
LLM_MODEL = "qwen/qwen3-coder-480b-a35b-instruct"

TAVILY_API_KEY = "tvly-..."

ARC_RPC = "https://rpc.testnet.arc-node.thecanteenapp.com/v1/yourkey"
AGENT_ADDRESS = "0x..."
AGENT_PRIVATE_KEY = "0x..."

MIN_EV_THRESHOLD = "0.05"
MIN_VOLUME = "10000"
TOP_N_PICKS = "10"
ARC_ENABLED = "true"
