# ─── LLM Provider — pick ONE block, comment out the others ───────────────────
#
# Option A — Groq (fastest, free tier, best tool calling) → console.groq.com
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_...
LLM_MODEL=llama-3.3-70b-versatile
#
# Option B — NVIDIA NIM (free, large premium models) → integrate.api.nvidia.com
# LLM_PROVIDER=nvidia
# LLM_API_KEY=nvapi-...
# LLM_MODEL=meta/llama-3.1-70b-instruct
#
# Option C — OpenAI or any compatible endpoint (paid) → platform.openai.com
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1

# ─── Search ────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ─── Arc testnet ───────────────────────────────────────────────────────────────
ARC_RPC=https://rpc.testnet.arc-node.thecanteenapp.com/v1/yourkey
AGENT_ADDRESS=0x...
AGENT_PRIVATE_KEY=0x...
ARC_USDC_CONTRACT=0x3600000000000000000000000000000000000000

# ─── Agent config ──────────────────────────────────────────────────────────────
MIN_EV_THRESHOLD=0.05
MIN_VOLUME=10000
TOP_N_PICKS=10

# ─── Tier 3 execution (dry-run — no real CLOB orders) ─────────────────────────
EXECUTION_DRY_RUN=true
FALLBACK_BANKROLL=100
MAX_POSITION_FRACTION=0.10
MAX_TOTAL_EXPOSURE_FRACTION=0.35
MAX_THEME_EXPOSURE_FRACTION=0.20
DRAWDOWN_PAUSE_THRESHOLD=-0.10
HEDGE_MOVE_THRESHOLD=0.12
EARLY_CLOSE_PROFIT_THRESHOLD=0.20
EARLY_CLOSE_LOSS_THRESHOLD=-0.15
SLIPPAGE_DEPTH_FRACTION=0.25
ARBITRAGE_MIN_DIVERGENCE=0.08

# ─── Tier 2 intelligence (optional) ───────────────────────────────────────────
RECENCY_DECAY_DAYS=30
CLOB_ENABLED=true
CLOB_BASE_URL=https://clob.polymarket.com
DOMAIN_ROUTING_ENABLED=true
# Multi-LLM ensemble (slower; needs keys for multiple providers)
ENSEMBLE_ENABLED=false
ENSEMBLE_DISAGREEMENT_THRESHOLD=0.15
SOCIAL_ENABLED=false
# TWITTER_BEARER_TOKEN=

# ─── Feature flags ─────────────────────────────────────────────────────────────
ARC_ENABLED=true

# ─── x402 micro-payments ───────────────────────────────────────────────────────
X402_PRICE_USDC=0.01
X402_ENABLED=true
# How far back (in blocks) to scan for a matching USDC transfer.
# Arc testnet ≈ 0.5s/block → 50,000 ≈ 7 hours. Increase for longer testing windows.
X402_SCAN_BLOCKS=50000
# Chunk size for paginated eth_getLogs calls (avoids RPC range limits).
X402_SCAN_CHUNK=5000

# ─── Circle (optional — enables Programmable Wallets) ─────────────────────────
# Get from: console.circle.com
# CIRCLE_API_KEY=TEST_API_KEY:...
# CIRCLE_ENTITY_SECRET=<32-byte hex — generate locally, register with Circle>
# CIRCLE_WALLET_SET_ID=<UUID from Circle console>
# CIRCLE_WALLET_ID=<written automatically by agora init when Circle is configured>
